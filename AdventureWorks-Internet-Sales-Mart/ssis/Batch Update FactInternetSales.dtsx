      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{EBA3A0B0-122B-4D2D-8D86-C987362004D8}"
          SQLTask:SqlStatementSource="UPDATE dbo.FactInternetSales&#xA;  SET UnitPrice = sif.UnitPrice, OrderQuantity = sif.OrderQty, ShipDateKey = sif.ShipDateKey, SalesAmount = sif.SubTotal&#xA;  FROM dbo.FactInternetSales fis&#xA;    INNER JOIN  AdventureWorksDW.stage.FactInternetSalesChanges sif&#xA;      ON sif.matchSalesOrderNumber = fis.SalesOrderNumber&#xA;        AND sif.matchSalesOrderLineNumber = fis.SalesOrderLineNumber" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
